# Cloudflare API token with Radar read access
# Get it from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Supabase project settings
# Get them from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LM Studio (local LLM server)
# Default points to a locally running LM Studio instance
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen/qwen2.5-vl-7b

# Timezone for UI display (timestamps are stored as UTC in DB)
APP_TIMEZONE=Europe/Bucharest

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
