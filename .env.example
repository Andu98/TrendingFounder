# Copy this to .env and fill in the values
CLOUDFLARE_API_TOKEN=your_cloudflare_token

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PROJECT_ID=your_project_id
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ACCESS_TOKEN=your_access_token

LMSTUDIO_BASE_URL=https://integrate.api.nvidia.com/v1
LMSTUDIO_MODEL=meta/llama-3.1-8b-instruct
APP_TIMEZONE=Europe/Bucharest

# Optional: raises GitHub Search API rate limits for ./start-git-crawl
GITHUB_TOKEN=your_github_token

# Bearer token for the LLM endpoint above (NVIDIA NIM).
# Leave empty if you point LMSTUDIO_BASE_URL at a local server that needs no auth.
NVIDIA_API_KEY=your_nvidia_api_key
