# Copy to .streamlit/secrets.toml and fill in. Used by the Run Crawl panel.

# owner/repo on GitHub
GH_REPO = "your-username/TrendingFounder"

# Fine-grained PAT scoped to this repo with permissions:
#   Actions: Read and write
#   Metadata: Read-only
GH_DISPATCH_TOKEN = "github_pat_..."

# Optional overrides
# GH_WORKFLOW_FILE = "crawl.yml"
# GH_WORKFLOW_REF  = "main"
