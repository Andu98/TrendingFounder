#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PYTHON="$ROOT_DIR/.venv/bin/python"

CMD="${1:-}"

case "$CMD" in
  trending)
    shift
    if [[ -x "$VENV_PYTHON" ]]; then
      exec "$VENV_PYTHON" -m streamlit run "$ROOT_DIR/app/streamlit_app.py" "$@"
    fi
    if command -v uv >/dev/null 2>&1; then
      exec uv run streamlit run "$ROOT_DIR/app/streamlit_app.py" "$@"
    fi
    echo "Could not find .venv/bin/python or uv. Run: uv sync"
    exit 1
    ;;

  crawler)
    shift
    # Ensure NVIDIA proxy (project‑local) is running
    if [ -d "$ROOT_DIR/nvidia-proxy" ] && [ -f "$ROOT_DIR/nvidia-proxy/index.js" ]; then
      if ! pgrep -f "node index.js" >/dev/null; then
        (cd "$ROOT_DIR/nvidia-proxy" && nohup node nvidia-proxy.js >/dev/null 2>&1 &)
      fi
    else
      echo "Warning: nvidia‑proxy directory or index.js not found; skipping proxy start."
    fi
    if [[ -x "$VENV_PYTHON" ]]; then
      exec "$VENV_PYTHON" -m src.crawler.run_daily "$@"
    fi
    if command -v uv >/dev/null 2>&1; then
      exec uv run python -m src.crawler.run_daily "$@"
    fi
    echo "Could not find .venv/bin/python or uv. Run: uv sync"
    exit 1
    ;;

  *)
    echo "Usage:"
    echo "  ./start trending [streamlit args]"
    echo "  ./start crawler [crawler args]"
    echo
    echo "Examples:"
    echo "  ./start trending"
    echo "  ./start trending --server.port 8502"
    echo "  ./start crawler"
    echo "  ./start crawler --limit 50"
    echo "  ./start crawler --skip-llm"
    echo "  ./start crawler --date 2026-05-15"
    exit 2
    ;;
esac
