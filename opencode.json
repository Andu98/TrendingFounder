{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=fnuqhnzuobliapdwolaw&features=development%2Cfunctions%2Cstorage%2Cbranching%2Cdatabase%2Cdebugging%2Caccount%2Cdocs",
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated=true",
        "--channel=stable"
      ],
      "enabled": true
    }
  }
}
