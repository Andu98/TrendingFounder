#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PYTHON="$ROOT_DIR/.venv/bin/python"
DEFAULT_MODEL="meta/llama-3.1-8b-instruct"

usage() {
  cat <<'EOF'
Usage:
  ./start-score [update-opportunity-scores args]

Calls NVIDIA NIM (or whichever endpoint LMSTUDIO_BASE_URL points at)
and runs:
  .venv/bin/python main.py update-opportunity-scores \
    --fetch-homepage \
    --only-missing \
    --concurrency 3 \
    --llm-concurrency 1 \
    --model meta/llama-3.1-8b-instruct

Extra args are appended, so you can add flags like:
  ./start-score --force
  ./start-score --limit 50 --dry-run
  ./start-score --model other/model
EOF
}

load_env() {
  if [[ -f "$ROOT_DIR/.env" ]]; then
    set -a
    # shellcheck disable=SC1091
    source "$ROOT_DIR/.env"
    set +a
  fi
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

load_env

if [[ -z "${NVIDIA_API_KEY:-}" ]]; then
  echo "Warning: NVIDIA_API_KEY is not set; LLM requests may be rejected." >&2
fi

if [[ -x "$VENV_PYTHON" ]]; then
  exec "$VENV_PYTHON" "$ROOT_DIR/main.py" update-opportunity-scores \
    --fetch-homepage \
    --only-missing \
    --concurrency 3 \
    --llm-concurrency 1 \
    --model "$DEFAULT_MODEL" \
    "$@"
fi

if command -v uv >/dev/null 2>&1; then
  exec uv run python "$ROOT_DIR/main.py" update-opportunity-scores \
    --fetch-homepage \
    --only-missing \
    --concurrency 3 \
    --llm-concurrency 1 \
    --model "$DEFAULT_MODEL" \
    "$@"
fi

echo "Could not find .venv/bin/python or uv. Run: uv sync" >&2
exit 1
