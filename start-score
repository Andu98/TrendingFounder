#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PYTHON="$ROOT_DIR/.venv/bin/python"
DEFAULT_MODEL="meta/llama-3.1-8b-instruct"

usage() {
  cat <<'EOF'
Usage:
  ./start-score [update-opportunity-scores args]

Starts the local NVIDIA proxy on http://127.0.0.1:1234/v1, then runs:
  .venv/bin/python main.py update-opportunity-scores \
    --fetch-homepage \
    --only-missing \
    --concurrency 3 \
    --llm-concurrency 1 \
    --model meta/llama-3.1-8b-instruct

Extra args are appended, so you can add flags like:
  ./start-score --force
  ./start-score --limit 50 --dry-run
  ./start-score --model other/model
EOF
}

load_env() {
  if [[ -f "$ROOT_DIR/.env" ]]; then
    set -a
    # shellcheck disable=SC1091
    source "$ROOT_DIR/.env"
    set +a
  fi
}

ensure_nvidia_proxy() {
  local proxy_script="$ROOT_DIR/nvidia-proxy.js"
  mkdir -p "$ROOT_DIR/logs"

  if [[ ! -f "$proxy_script" ]]; then
    echo "Error: nvidia-proxy.js not found." >&2
    exit 1
  fi

  load_env

  if [[ -z "${NVIDIA_API_KEY:-}" ]]; then
    echo "Warning: NVIDIA_API_KEY is not set; proxy may reject scoring requests." >&2
  fi

  if pgrep -f "node .*nvidia-proxy.js" >/dev/null; then
    echo "NVIDIA proxy already running."
  else
    echo "Starting NVIDIA proxy..."
    nohup node "$proxy_script" >>"$ROOT_DIR/logs/nvidia-proxy.log" 2>&1 &
  fi

  if command -v nc >/dev/null 2>&1; then
    for _ in {1..20}; do
      if nc -z 127.0.0.1 1234 >/dev/null 2>&1; then
        echo "NVIDIA proxy ready on http://127.0.0.1:1234/v1"
        return 0
      fi
      sleep 0.25
    done
    echo "Error: NVIDIA proxy did not become reachable on 127.0.0.1:1234." >&2
    echo "Check logs/nvidia-proxy.log." >&2
    exit 1
  fi
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

ensure_nvidia_proxy

if [[ -x "$VENV_PYTHON" ]]; then
  exec "$VENV_PYTHON" "$ROOT_DIR/main.py" update-opportunity-scores \
    --fetch-homepage \
    --only-missing \
    --concurrency 3 \
    --llm-concurrency 1 \
    --model "$DEFAULT_MODEL" \
    "$@"
fi

if command -v uv >/dev/null 2>&1; then
  exec uv run python "$ROOT_DIR/main.py" update-opportunity-scores \
    --fetch-homepage \
    --only-missing \
    --concurrency 3 \
    --llm-concurrency 1 \
    --model "$DEFAULT_MODEL" \
    "$@"
fi

echo "Could not find .venv/bin/python or uv. Run: uv sync" >&2
exit 1
